{
  "version": 3,
  "configurePresets": [
    {
      "name": "android-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android",
      "cacheVariables": {
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-21",
        "ANDROID_STL": "c++_static",
        "CMAKE_SYSTEM_NAME": "Android",
        "ANDROID_NATIVE_API_LEVEL": "21",
        "CMAKE_SYSTEM_VERSION": "21",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_ROOT}",
        "CMAKE_HOST_SYSTEM_NAME": "Windows",
        "ANDROID_HOST_TAG": "windows-x86_64",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MAKE_PROGRAM": "D:/dev/android_sdk/cmake/3.22.1/bin/ninja.exe"
      },
      "toolchainFile": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
      "environment": {
        "ANDROID_NDK_ROOT": "D:/dev/android_sdk/ndk/28.2.13676358",
        "PATH": "D:/dev/android_sdk/cmake/3.22.1/bin;$penv{PATH}"
      }
    },
    {
      "name": "android-debug",
      "inherits": "android-base",
      "displayName": "Android Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "android-release",
      "inherits": "android-base",
      "displayName": "Android Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "android-debug",
      "configurePreset": "android-debug"
    },
    {
      "name": "android-release",
      "configurePreset": "android-release"
    }
  ]
}
